{
    "manifest_version": 2,
    "name": "Hide YouTube Shorts",
    "version": "1.0",
    "description": "Hides YouTube Shorts",
    "permissions": [
      "activeTab"
    ],
    "content_scripts": [
      {
        "matches": ["https://www.youtube.com/*"],
        "js": ["content.js"],
        "run_at": "document_end"
      }
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "pankaj@gmail.com"
      }
    }
  }

